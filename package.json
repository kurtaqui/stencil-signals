{
  "name": "@kurtaqui/stencil-signals",
  "version": "0.1.0",
  "description": "TC39 Signals integration for StencilJS",
  "homepage": "https://github.com/kurtaqui/stencil-signals#readme",
  "bugs": "https://github.com/kurtaqui/stencil-signals/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurtaqui/stencil-signals.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "demo": "vite demo --open",
    "lint": "oxlint src/",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "signal-polyfill": "^0.2.0"
  },
  "devDependencies": {
    "@stencil/core": ">=4.43.0",
    "oxlint": "^1.63.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@stencil/core": ">=4.43.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
